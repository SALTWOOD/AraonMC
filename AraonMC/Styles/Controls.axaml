<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="using:AraonMC.Controls">

    <!-- Primary amber button (PLAY / confirm) -->
    <Style Selector="Button.accent">
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource AccentForegroundBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="20,10"/>
    </Style>
    <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
    </Style>
    <Style Selector="Button.accent:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource AccentActiveBrush}"/>
    </Style>

    <!-- Subtle / secondary button -->
    <Style Selector="Button.subtle">
        <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,9"/>
    </Style>
    <Style Selector="Button.subtle:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
    </Style>

    <!-- Danger button -->
    <Style Selector="Button.danger">
        <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,9"/>
    </Style>
    <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource DangerHoverBrush}"/>
    </Style>

    <!-- Flat: transparent, used for nav items / cards; only hover shows a tint -->
    <Style Selector="Button.flat">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
    </Style>
    <Style Selector="Button.flat:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
        <Setter Property="CornerRadius" Value="10"/>
    </Style>

    <!-- Square icon button (e.g. notification close). Transparent, circular hover, no shadow. -->
    <Style Selector="Button.icon">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="CornerRadius" Value="14"/>
    </Style>
    <Style Selector="Button.icon:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
        <Setter Property="CornerRadius" Value="14"/>
    </Style>

    <!-- Chrome window buttons -->
    <Style Selector="Button.chrome">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Width" Value="46"/>
        <Setter Property="Height" Value="32"/>
    </Style>
    <Style Selector="Button.chrome Path">
        <Setter Property="Stroke" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="StrokeThickness" Value="1.5"/>
        <Setter Property="Fill" Value="Transparent"/>
        <Setter Property="Width" Value="14"/>
        <Setter Property="Height" Value="14"/>
        <Setter Property="Stretch" Value="Uniform"/>
    </Style>
    <Style Selector="Button.chrome:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
    </Style>
    <Style Selector="Button.chrome#closeBtn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
    </Style>
    <Style Selector="Button.chrome#closeBtn:pointerover Path">
        <Setter Property="Stroke" Value="White"/>
    </Style>

    <!-- Text field -->
    <Style Selector="TextBox.field">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Padding" Value="10,7"/>
    </Style>
    <Style Selector="TextBox.field:focus /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
    </Style>

    <!-- Cards / surfaces -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderSoftBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource LargeCornerRadius}"/>
    </Style>
    <Style Selector="Border.divider">
        <Setter Property="Background" Value="{StaticResource BorderSoftBrush}"/>
        <Setter Property="Height" Value="1"/>
    </Style>

    <!-- Avatar circle -->
    <Style Selector="Border.avatar">
        <Setter Property="CornerRadius" Value="999"/>
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Slim scrollbars -->
    <Style Selector="ScrollBar.vertical">
        <Setter Property="Width" Value="10"/>
    </Style>
    <Style Selector="ScrollBar.horizontal">
        <Setter Property="Height" Value="10"/>
    </Style>

    <!-- ============================== -->
    <!--  Combox  (Modrinth-style combobox)  -->
    <!-- ============================== -->
    <Style Selector="ctrl|Combox">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="Template">
            <ControlTemplate TargetType="ctrl:Combox">
                <Grid Name="PART_Root">
                    <!-- Trigger button: rounded-xl, bg-surface-4, px-4 py-2, gap-2.5 -->
                    <Border Name="PART_Border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="12"
                            Padding="16,7"
                            MinHeight="36"
                            BorderThickness="0"
                            Cursor="Hand">
                        <Grid ColumnDefinitions="*,Auto">
                            <!-- Selected text or placeholder -->
                            <TextBlock Name="PART_SelectedText"
                                       Grid.Column="0"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Left"
                                       TextTrimming="CharacterEllipsis"
                                       FontSize="13"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Opacity="0.7"/>

                            <!-- Chevron: size-5, text-secondary -->
                            <Grid Name="PART_ChevronContainer"
                                  Grid.Column="1"
                                  Width="15" Height="15"
                                  VerticalAlignment="Center"
                                  Margin="10,0,0,0"
                                  RenderTransformOrigin="50%, 50%">
                                <Path Name="PART_Chevron"
                                      Stretch="Uniform"
                                      Fill="Transparent"
                                      Stroke="{DynamicResource TextSecondaryBrush}"
                                      StrokeThickness="2"
                                      StrokeLineCap="Round"
                                      StrokeJoin="Round"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Data="M6,9 L12,15 L18,9"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Dropdown Popup -->
                    <Popup Name="PART_Popup"
                           Placement="Bottom"
                           HorizontalOffset="0"
                           VerticalOffset="8"
                           PlacementTarget="{TemplateBinding}">
                        <Border Name="PART_DropdownBorder"
                                Background="{DynamicResource SurfaceBrush}"
                                CornerRadius="14"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                Padding="0"
                                MaxHeight="300"
                                UseLayoutRounding="True">
                            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto">
                                <ListBox Name="PART_ListBox"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="4"
                                         ItemsSource="{TemplateBinding ItemsSource}"
                                         SelectedItem="{TemplateBinding SelectedItem}"
                                         ItemTemplate="{TemplateBinding ItemTemplate}"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                         Focusable="False">
                                    <ListBox.Styles>
                                        <!-- Modrinth-style ListBoxItem -->
                                        <Style Selector="ListBoxItem">
                                            <Setter Property="Padding" Value="16,11"/>
                                            <Setter Property="Margin" Value="0"/>
                                            <Setter Property="MinHeight" Value="0"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="FontSize" Value="13"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                            <Setter Property="CornerRadius" Value="10"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                        </Style>
                                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                                            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                                        </Style>
                                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                            <Setter Property="Background" Value="{DynamicResource AccentTintBrush}"/>
                                        </Style>
                                        <Style Selector="ListBoxItem:selected">
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                        </Style>
                                        <Style Selector="ListBoxItem:focusvisual">
                                            <Setter Property="IsVisible" Value="False"/>
                                        </Style>
                                    </ListBox.Styles>
                                </ListBox>
                            </ScrollViewer>
                        </Border>
                    </Popup>
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>

</Styles>
