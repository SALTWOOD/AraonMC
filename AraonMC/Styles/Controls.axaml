<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:AraonMC.Controls">

    <!-- Primary accent button (PLAY / confirm) -->
    <Style Selector="Button.accent">
        <Setter Property="Background" Value="{DynamicResource ColorBrush4}"/>
        <Setter Property="Foreground" Value="{DynamicResource ColorBrush1}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="20,10"/>
    </Style>
    <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ColorBrush3}"/>
    </Style>
    <Style Selector="Button.accent:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ColorBrush2}"/>
    </Style>

    <!-- Subtle / secondary button -->
    <Style Selector="Button.subtle">
        <Setter Property="Background" Value="{DynamicResource ColorBrushGray6}"/>
        <Setter Property="Foreground" Value="{DynamicResource ColorBrushGray1}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,9"/>
    </Style>
    <Style Selector="Button.subtle:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ColorBrushGray4}"/>
    </Style>

    <!-- Danger button -->
    <Style Selector="Button.danger">
        <Setter Property="Background" Value="{DynamicResource ColorBrushDanger}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,9"/>
    </Style>
    <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ColorBrushDangerHover}"/>
    </Style>

    <!-- Flat: transparent, used for nav items / cards; only hover shows a tint -->
    <Style Selector="Button.flat">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
    </Style>
    <Style Selector="Button.flat:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ColorBrushGray6}"/>
        <Setter Property="CornerRadius" Value="10"/>
    </Style>

    <!-- Square icon button (e.g. notification close). Transparent, circular hover, no shadow. -->
    <Style Selector="Button.icon">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="CornerRadius" Value="14"/>
    </Style>
    <Style Selector="Button.icon:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ColorBrushGray6}"/>
        <Setter Property="CornerRadius" Value="14"/>
    </Style>
    <Style Selector="Button.icon:pointerover Path">
        <Setter Property="Stroke" Value="{DynamicResource ColorBrushGray1}"/>
    </Style>

    <!-- Chrome window buttons -->
    <Style Selector="Button.chrome">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource ColorBrushGray2}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Width" Value="46"/>
        <Setter Property="Height" Value="32"/>
    </Style>
    <Style Selector="Button.chrome Path">
        <Setter Property="Stroke" Value="{DynamicResource ColorBrushGray2}"/>
        <Setter Property="StrokeThickness" Value="1.5"/>
        <Setter Property="Fill" Value="Transparent"/>
        <Setter Property="Width" Value="14"/>
        <Setter Property="Height" Value="14"/>
        <Setter Property="Stretch" Value="Uniform"/>
    </Style>
    <Style Selector="Button.chrome:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ColorBrushGray6}"/>
    </Style>
    <Style Selector="Button.chrome#closeBtn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ColorBrushDanger}"/>
    </Style>
    <Style Selector="Button.chrome#closeBtn:pointerover Path">
        <Setter Property="Stroke" Value="White"/>
    </Style>

    <!-- Text field -->
    <Style Selector="TextBox.field">
        <Setter Property="Background" Value="{DynamicResource ColorBrushGray5}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ColorBrushGray4}"/>
        <Setter Property="Foreground" Value="{DynamicResource ColorBrushGray1}"/>
        <Setter Property="CaretBrush" Value="{DynamicResource ColorBrush4}"/>
        <Setter Property="Padding" Value="10,7"/>
    </Style>
    <Style Selector="TextBox.field:focus /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{DynamicResource ColorBrush4}"/>
    </Style>
    <!-- Cards / surfaces -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="{DynamicResource ColorBrushGray5}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ColorBrushGray7}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource LargeCornerRadius}"/>
    </Style>
    <Style Selector="Border.card:pointerover">
        <Setter Property="Background" Value="{DynamicResource ColorBrushGray6}"/>
    </Style>
    <Style Selector="Border.divider">
        <Setter Property="Background" Value="{DynamicResource ColorBrushGray7}"/>
        <Setter Property="Height" Value="1"/>
    </Style>

    <!-- Avatar circle -->
    <Style Selector="Border.avatar">
        <Setter Property="CornerRadius" Value="999"/>
        <Setter Property="Background" Value="{DynamicResource ColorBrush4}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Slim scrollbars -->
    <Style Selector="ScrollBar.vertical">
        <Setter Property="Width" Value="10"/>
    </Style>
    <Style Selector="ScrollBar.horizontal">
        <Setter Property="Height" Value="10"/>
    </Style>

    <!-- ============================== -->
    <!--  ComboBox -->
    <!-- ============================== -->
    <Style Selector="controls|ComboBox">
        <Setter Property="Background" Value="{DynamicResource ColorBrushGray5}"/>
        <Setter Property="Foreground" Value="{DynamicResource ColorBrushGray1}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ColorBrushGray7}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="Template">
            <ControlTemplate TargetType="controls:ComboBox">
                <Grid Name="PART_Root">
                    <Border Name="PART_Border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="12"
                            Padding="16,7"
                            MinHeight="36"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            Cursor="Hand">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Name="PART_SelectedText"
                                       Grid.Column="0"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Left"
                                       TextTrimming="CharacterEllipsis"
                                       FontSize="13"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource ColorBrushGray2}"
                                       Opacity="0.7"/>

                            <Grid Name="PART_ChevronContainer"
                                  Grid.Column="1"
                                  Width="15" Height="15"
                                  VerticalAlignment="Center"
                                  Margin="10,0,0,0"
                                  RenderTransformOrigin="50%, 50%">
                                <Path Name="PART_Chevron"
                                      Stretch="Uniform"
                                      Fill="Transparent"
                                      Stroke="{DynamicResource ColorBrushGray2}"
                                      StrokeThickness="2"
                                      StrokeLineCap="Round"
                                      StrokeJoin="Round"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Data="M6,9 L12,15 L18,9"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <Popup Name="PART_Popup"
                           Placement="Bottom"
                           HorizontalOffset="0"
                           VerticalOffset="8"
                           PlacementTarget="{TemplateBinding}">
                        <Border Name="PART_DropdownBorder"
                                Background="{DynamicResource ColorBrushGray5}"
                                CornerRadius="14"
                                BorderBrush="{DynamicResource ColorBrushGray4}"
                                BorderThickness="1"
                                Padding="0"
                                MaxHeight="300"
                                UseLayoutRounding="True">
                            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto">
                                <ListBox Name="PART_ListBox"
                                         Background="Transparent"
                                         Foreground="{DynamicResource ColorBrushGray1}"
                                         BorderThickness="0"
                                         Padding="4"
                                         ItemsSource="{TemplateBinding ItemsSource}"
                                         SelectedItem="{TemplateBinding SelectedItem}"
                                         ItemTemplate="{TemplateBinding ItemTemplate}"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                         Focusable="False">
                                    <ListBox.Styles>
                                        <Style Selector="ListBoxItem">
                                            <Setter Property="Padding" Value="16,11"/>
                                            <Setter Property="Margin" Value="0"/>
                                            <Setter Property="MinHeight" Value="0"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="FontSize" Value="13"/>
                                            <Setter Property="CornerRadius" Value="10"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                        </Style>
                                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                                            <Setter Property="Background" Value="{DynamicResource ColorBrushGray6}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource ColorBrushGray1}"/>
                                        </Style>
                                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                            <Setter Property="Background" Value="{DynamicResource ColorBrush4}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource ColorBrushGray1}"/>
                                        </Style>
                                        <Style Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter">
                                            <Setter Property="Background" Value="{DynamicResource ColorBrush3}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource ColorBrushGray1}"/>
                                        </Style>
                                        <Style Selector="ListBoxItem:focusvisual">
                                            <Setter Property="IsVisible" Value="False"/>
                                        </Style>
                                    </ListBox.Styles>
                                </ListBox>
                            </ScrollViewer>
                        </Border>
                    </Popup>
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="controls|ComboBox:pointerover /template/ Border#PART_Border">
        <Setter Property="BorderBrush" Value="{DynamicResource ColorBrushGray4}"/>
    </Style>

</Styles>
