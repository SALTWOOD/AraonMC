<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AraonMC.Accounts"
        x:Class="AraonMC.Accounts.DeviceCodeWindow"
        x:DataType="vm:DeviceCodeWindowViewModel"
        Title="Microsoft Sign-In"
        Width="440"
        SizeToContent="Height"
        CanResize="False"
        ShowInTaskbar="False"
        ShowActivated="True"
        Background="Transparent"
        TransparencyBackgroundFallback="#FF252538"
        ExtendClientAreaToDecorationsHint="True"
        WindowDecorations="None"
        ExtendClientAreaTitleBarHeightHint="-1"
        WindowStartupLocation="CenterOwner">

    <Border CornerRadius="14"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            ClipToBounds="True">

        <Grid RowDefinitions="Auto,Auto,Auto">

            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource SidebarBrush}" Padding="18,13">
                <Grid ColumnDefinitions="Auto,*">
                    <Border Grid.Column="0" Width="30" Height="30" CornerRadius="15" Background="{DynamicResource AccentBrush}">
                        <TextBlock Text="M" Foreground="{DynamicResource AccentForegroundBrush}" FontWeight="Bold" FontSize="15"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Grid.Column="1" Text="Sign in with Microsoft" FontSize="15" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="12,0,0,0" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Body -->
            <StackPanel Grid.Row="1" Margin="18,16" Spacing="12">
                <TextBlock Text="Open the link below in your browser, then enter the code to authorize:"
                           TextWrapping="Wrap" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding VerificationUrl}" FontSize="13" Foreground="{DynamicResource AccentBrush}"/>

                <Border CornerRadius="10" Background="{DynamicResource AccentTintBrush}" Padding="14,12">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="{Binding UserCode}" FontSize="30" FontWeight="Bold"
                                   FontFamily="Consolas"
                                   Foreground="{DynamicResource AccentBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Classes="subtle" VerticalAlignment="Center" Click="Copy_Click">
                            <TextBlock Text="Copy" FontWeight="SemiBold" FontSize="12"/>
                        </Button>
                    </Grid>
                </Border>

                <ProgressBar IsIndeterminate="True" Height="3"/>
                <TextBlock Text="Waiting for browser authorization to complete…" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
            </StackPanel>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" Padding="18,0,14,14">
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <Button Classes="accent" Click="Open_Click" MinWidth="120">
                        <TextBlock Text="Open Browser" FontWeight="SemiBold"/>
                    </Button>
                    <Button Classes="danger" Click="Cancel_Click" MinWidth="96">
                        <TextBlock Text="Cancel" FontWeight="SemiBold"/>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
