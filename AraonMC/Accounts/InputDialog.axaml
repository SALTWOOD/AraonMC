<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AraonMC.Accounts.InputDialog"
        Title="Input"
        Width="380"
        SizeToContent="Height"
        CanResize="False"
        ShowInTaskbar="False"
        ShowActivated="True"
        Background="Transparent"
        TransparencyBackgroundFallback="#FF252538"
        ExtendClientAreaToDecorationsHint="True"
        WindowDecorations="None"
        ExtendClientAreaTitleBarHeightHint="-1"
        WindowStartupLocation="CenterOwner">

    <Border CornerRadius="14"
            Background="{DynamicResource ColorBrushGray5}"
            BorderBrush="{DynamicResource ColorBrushGray4}"
            BorderThickness="1"
            ClipToBounds="True"
            Padding="20">

        <StackPanel Spacing="14">
            <TextBlock x:Name="DialogTitle" FontSize="15" FontWeight="Bold"
                       Foreground="{DynamicResource ColorBrushGray1}"/>
            <TextBox x:Name="InputBox" FontSize="14" Padding="10,8"/>
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button Classes="subtle" Click="Cancel_Click" MinWidth="80">
                    <TextBlock Text="Cancel" FontWeight="SemiBold"/>
                </Button>
                <Button Classes="accent" Click="Ok_Click" MinWidth="80">
                    <TextBlock Text="OK" FontWeight="SemiBold"/>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
