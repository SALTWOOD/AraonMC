<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AraonMC.Accounts.ConfirmDialog"
        Title="Confirm"
        Width="400"
        SizeToContent="Height"
        CanResize="False"
        ShowInTaskbar="False"
        ShowActivated="True"
        Background="Transparent"
        TransparencyBackgroundFallback="#FF252538"
        ExtendClientAreaToDecorationsHint="True"
        WindowDecorations="None"
        ExtendClientAreaTitleBarHeightHint="-1"
        WindowStartupLocation="CenterOwner">

    <Border CornerRadius="14"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            ClipToBounds="True"
            Padding="20">

        <StackPanel Spacing="14">
            <TextBlock x:Name="DialogTitle" FontSize="15" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock x:Name="DialogMessage" FontSize="13" TextWrapping="Wrap"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button Classes="subtle" Click="Cancel_Click" MinWidth="80">
                    <TextBlock Text="Cancel" FontWeight="SemiBold"/>
                </Button>
                <Button Classes="accent" Click="Confirm_Click" MinWidth="80">
                    <TextBlock x:Name="ConfirmLabel" Text="Confirm" FontWeight="SemiBold"/>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
