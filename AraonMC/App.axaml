<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AraonMC.App"
             xmlns:local="using:AraonMC"
             xmlns:conv="using:AraonMC.Converters">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://AraonMC/Styles/Colors.axaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:BoolToStatusConverter x:Key="BoolToStatus"/>
            <conv:NotificationLevelConverter x:Key="NotificationLevel"/>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme/>
        <StyleInclude Source="avares://AraonMC/Styles/Controls.axaml"/>
    </Application.Styles>
</Application>
