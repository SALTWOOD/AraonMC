<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AraonMC.ViewModels"
        xmlns:models="using:AraonMC.Core.Domain.Entities"
        xmlns:conv="using:AraonMC.Converters"
        x:Class="AraonMC.Views.ResourceVersionWindow"
        Title="Select a version"
        Width="680" Height="600"
        CanResize="True"
        ShowInTaskbar="False"
        ShowActivated="True"
        Background="Transparent"
        TransparencyBackgroundFallback="#FF1B1B2A"
        ExtendClientAreaToDecorationsHint="True"
        WindowDecorations="None"
        ExtendClientAreaTitleBarHeightHint="-1"
        WindowStartupLocation="CenterOwner"
        x:DataType="vm:ResourceVersionViewModel">

    <Border CornerRadius="14"
            Background="{DynamicResource ColorBrushBackground}"
            BorderBrush="{DynamicResource ColorBrushGray4}"
            BorderThickness="1"
            ClipToBounds="True">

        <DockPanel LastChildFill="True">

            <!-- Header -->
            <Border DockPanel.Dock="Top" Padding="22,16"
                    Background="{DynamicResource ColorBrushGray5}"
                    BorderBrush="{DynamicResource ColorBrushGray7}" BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="{Binding Resource.Name}" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource ColorBrushGray1}"/>
                        <TextBlock Text="{Binding Resource.Author}" FontSize="11"
                                   Foreground="{DynamicResource ColorBrushGray3}"/>
                    </StackPanel>
                    <Button Grid.Column="1" Classes="icon" Width="32" Height="32"
                            VerticalAlignment="Center" Click="Close_Click">
                        <Path Width="14" Height="14" Stretch="Uniform"
                              Stroke="{DynamicResource ColorBrushGray2}" StrokeThickness="1.5"
                              Fill="Transparent" Data="{StaticResource x}"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Body: loading / empty / error states + accordion -->
            <ScrollViewer Padding="22,16" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <ProgressBar IsVisible="{Binding IsLoading}" IsIndeterminate="True"
                                 Height="3" Margin="0,0,0,14"
                                 Foreground="{DynamicResource ColorBrush4}"/>

                    <TextBlock IsVisible="{Binding IsEmpty}" Text="No downloadable versions found."
                               FontSize="13" Foreground="{DynamicResource ColorBrushGray3}" Margin="0,12,0,0"/>

                    <Border IsVisible="{Binding HasError}" Classes="card" Margin="0,0,0,0" Padding="14"
                            BorderBrush="{DynamicResource ColorBrushDanger}">
                        <TextBlock Text="{Binding ErrorMessage}" FontSize="12" TextWrapping="Wrap"
                                   Foreground="{DynamicResource ColorBrushDanger}"/>
                    </Border>

                    <ItemsControl ItemsSource="{Binding Groups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:VersionGroup">
                                <Border Classes="card" Margin="0,0,0,12" Padding="0">
                                    <StackPanel>
                                        <!-- Collapsible group header -->
                                        <Button Classes="flat" HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                Command="{Binding ToggleCommand}" Padding="16,12">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Grid.Column="0" Text="{Binding GameVersion}"
                                                           FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ColorBrushGray1}"
                                                           VerticalAlignment="Center"/>
                                                <Panel Grid.Column="1" Width="16" Height="16" VerticalAlignment="Center">
                                                    <Path Width="13" Height="13" Stretch="Uniform"
                                                          Stroke="{DynamicResource ColorBrushGray3}" StrokeThickness="1.6"
                                                          Fill="Transparent" Data="{StaticResource chevron-down}"
                                                          IsVisible="{Binding IsExpanded}"/>
                                                    <Path Width="13" Height="13" Stretch="Uniform"
                                                          Stroke="{DynamicResource ColorBrushGray3}" StrokeThickness="1.6"
                                                          Fill="Transparent" Data="{StaticResource chevron-down}"
                                                          IsVisible="{Binding !IsExpanded}"
                                                          RenderTransformOrigin="50%,50%">
                                                        <Path.RenderTransform>
                                                            <RotateTransform Angle="-90"/>
                                                        </Path.RenderTransform>
                                                    </Path>
                                                </Panel>
                                            </Grid>
                                        </Button>

                                        <!-- Versions for this game version -->
                                        <ItemsControl ItemsSource="{Binding Versions}" IsVisible="{Binding IsExpanded}"
                                                      Margin="6,0,6,12">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="models:ResourceVersion">
                                                    <Button Classes="flat" HorizontalAlignment="Stretch"
                                                            HorizontalContentAlignment="Stretch" Margin="0,0,0,4"
                                                            Command="{Binding $parent[Window].((vm:ResourceVersionViewModel)DataContext).PickCommand}"
                                                            CommandParameter="{Binding}">
                                                        <Grid ColumnDefinitions="*,Auto,Auto" Margin="10,8">
                                                            <StackPanel Grid.Column="0" Spacing="2">
                                                                <TextBlock Text="{Binding Name}" FontSize="13"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource ColorBrushGray1}"/>
                                                                <TextBlock Text="{Binding PublishedAt, StringFormat='\{0:yyyy-MM-dd\}'}"
                                                                           FontSize="11"
                                                                           Foreground="{DynamicResource ColorBrushGray3}"/>
                                                            </StackPanel>
                                                            <Border Grid.Column="1" Background="{DynamicResource ColorBrushGray6}"
                                                                    CornerRadius="5" Padding="8,2"
                                                                    VerticalAlignment="Center" Margin="10,0">
                                                                <TextBlock Text="{Binding ReleaseType}" FontSize="10"
                                                                           FontWeight="Bold"
                                                                           Foreground="{DynamicResource ColorBrushGray2}"/>
                                                            </Border>
                                                            <TextBlock Grid.Column="2"
                                                                       Text="{Binding SizeBytes, Converter={x:Static conv:FileSizeConverter.Instance}}"
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource ColorBrushGray3}"
                                                                       VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
