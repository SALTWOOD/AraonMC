<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:pages="using:AraonMC.ViewModels.Pages"
             xmlns:models="using:AraonMC.Core.Domain.Entities"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="640"
             x:Class="AraonMC.Views.Pages.VersionSelectView"
             x:DataType="pages:VersionSelectViewModel">

    <UserControl.Resources>
        <DataTemplate x:Key="VersionTemplate" DataType="models:MinecraftVersion">
            <Border Classes="card" Padding="14,12" Margin="0,0,0,8">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <TextBlock Grid.Column="0" Text="{Binding Id}" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding ReleaseTime, StringFormat='\{0:yyyy-MM-dd\}'}" FontSize="12"
                               Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <Button Grid.Column="2" Classes="accent" Padding="16,7"
                            Command="{Binding $parent[UserControl].((pages:VersionSelectViewModel)DataContext).InstallCommand}"
                            CommandParameter="{Binding}">
                        <TextBlock Text="Install" FontWeight="SemiBold"/>
                    </Button>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="28,8,28,28" RowDefinitions="Auto,*">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,4,0,18">
            <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    CornerRadius="8" Height="36">
                <Grid ColumnDefinitions="Auto,*">
                    <Path Grid.Column="0" Width="16" Height="16" Margin="10,0" Stretch="Uniform"
                          Fill="Transparent" Stroke="{DynamicResource TextMutedBrush}" StrokeThickness="1.5"
                          Data="{StaticResource search}"/>
                    <TextBox Grid.Column="1" Text="{Binding SearchText}" Watermark="Search versions..."
                             Background="Transparent" BorderThickness="0"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             CaretBrush="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                </Grid>
            </Border>
            <ComboBox Grid.Column="1" Width="160" Height="36"
                      ItemsSource="{Binding Filters}" SelectedItem="{Binding Filter}"/>
        </Grid>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Items}" ItemTemplate="{StaticResource VersionTemplate}"/>
        </ScrollViewer>
    </Grid>
</UserControl>
