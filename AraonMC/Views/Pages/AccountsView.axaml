<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:pages="using:AraonMC.ViewModels.Pages"
             xmlns:models="using:AraonMC.Core.Domain.Entities"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="640"
             x:Class="AraonMC.Views.Pages.AccountsView"
             x:DataType="pages:AccountsViewModel">

    <UserControl.Resources>
        <DataTemplate x:Key="AccountRowTemplate" DataType="models:MinecraftAccount">
            <Border Classes="card" Padding="16" Margin="0,0,0,12">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Border Classes="avatar" Width="44" Height="44" Background="{DynamicResource ColorBrush4}">
                        <TextBlock Text="{Binding AvatarKey}" FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource ColorBrush1}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="14,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding Username}" FontSize="15" FontWeight="Bold"
                                       Foreground="{DynamicResource ColorBrushGray1}"/>
                            <Border Background="{DynamicResource ColorBrushSemiTransparent}" CornerRadius="4" Padding="6,1"
                                    IsVisible="{Binding IsActive}">
                                <TextBlock Text="Active" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource ColorBrush4}"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,3,0,0">
                            <Ellipse Width="7" Height="7" Fill="{DynamicResource ColorBrushOnline}" IsVisible="{Binding IsOnline}" VerticalAlignment="Center"/>
                            <TextBlock Text="Online · Microsoft" FontSize="11" Foreground="{DynamicResource ColorBrushOnline}"
                                       IsVisible="{Binding IsOnline}"/>
                            <TextBlock Text="Offline profile" FontSize="11" Foreground="{DynamicResource ColorBrushGray3}"
                                       IsVisible="{Binding !IsOnline}"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button Classes="subtle" Padding="14,8"
                                Command="{Binding $parent[UserControl].((pages:AccountsViewModel)DataContext).SetActiveCommand}"
                                CommandParameter="{Binding}"
                                IsVisible="{Binding !IsActive}">
                            <TextBlock Text="Set Active" FontWeight="SemiBold" FontSize="12"/>
                        </Button>
                        <Button Classes="danger" Padding="14,8"
                                Command="{Binding $parent[UserControl].((pages:AccountsViewModel)DataContext).RemoveCommand}"
                                CommandParameter="{Binding}">
                            <TextBlock Text="Remove" FontWeight="SemiBold" FontSize="12"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="28,8,28,28" RowDefinitions="Auto,*">
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,4,0,18">
            <Button Classes="accent" Command="{Binding AddMicrosoftCommand}" Padding="16,9">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Path Width="14" Height="14" Stretch="Uniform"
                          Stroke="{DynamicResource ColorBrush1}" StrokeThickness="2"
                          StrokeLineCap="Round" StrokeJoin="Round"
                          Fill="Transparent"
                          Data="{StaticResource external-link}"/>
                    <TextBlock Text="Add Microsoft" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Classes="subtle" Command="{Binding AddOfflineCommand}" Padding="16,9">
                <TextBlock Text="Add Offline" FontWeight="SemiBold"/>
            </Button>
        </StackPanel>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
            <StackPanel MaxWidth="760" HorizontalAlignment="Left">
                <ItemsControl ItemsSource="{Binding Items}" ItemTemplate="{StaticResource AccountRowTemplate}"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
