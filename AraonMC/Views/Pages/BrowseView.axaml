<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:pages="using:AraonMC.ViewModels.Pages"
             xmlns:models="using:AraonMC.Core.Domain.Entities"
             xmlns:conv="using:AraonMC.Converters"
             xmlns:controls="using:AraonMC.Controls"
             xmlns:behaviors="using:AraonMC.Behaviors"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="640"
             x:Class="AraonMC.Views.Pages.BrowseView"
             x:DataType="pages:BrowseViewModel">

    <UserControl.Resources>
        <DataTemplate x:Key="ResourceCardTemplate" DataType="models:ResourceInfo">
            <Border Classes="card" Padding="16"
                    RenderTransformOrigin="50%,50%"
                    behaviors:CardBehavior.ReleaseCommand="{Binding $parent[UserControl].((pages:BrowseViewModel)DataContext).DetailCommand}"
                    behaviors:CardBehavior.ReleaseCommandParameter="{Binding}">
                <StackPanel>
                    <!-- Header: icon + name/author + open-page button -->
                    <Grid ColumnDefinitions="44,*,28">
                        <Border Grid.Column="0" Width="44" Height="44" CornerRadius="10"
                                Background="White" ClipToBounds="True">
                            <Panel>
                                <TextBlock Text="{Binding IconKey}" FontSize="15" FontWeight="Bold"
                                           Foreground="{DynamicResource ColorBrush1}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           IsVisible="{Binding IsLoaded, ElementName=IconImage, Converter={x:Static conv:BoolInvertConverter.Instance}}"/>
                                <controls:RemoteImage x:Name="IconImage" Url="{Binding IconUrl}" Stretch="UniformToFill"/>
                            </Panel>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource ColorBrushGray1}" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding Author}" FontSize="11"
                                       Foreground="{DynamicResource ColorBrushGray3}"/>
                        </StackPanel>
                        <Button Grid.Column="2" Classes="icon" Width="28" Height="28"
                                VerticalAlignment="Center" Cursor="Hand"
                                Command="{Binding $parent[UserControl].((pages:BrowseViewModel)DataContext).OpenPageCommand}"
                                CommandParameter="{Binding}">
                            <Path Width="13" Height="13" Stretch="Uniform"
                                  Stroke="{DynamicResource ColorBrushGray3}" StrokeThickness="1.8"
                                  StrokeLineCap="Round" StrokeJoin="Round"
                                  Fill="Transparent"
                                  Data="{StaticResource external-link}"/>
                        </Button>
                    </Grid>

                    <!-- Summary -->
                    <TextBlock Text="{Binding Summary}" FontSize="12" TextWrapping="Wrap"
                               MaxLines="3" TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource ColorBrushGray2}" Margin="0,12,0,0"/>

                    <!-- Meta: category + source badge -->
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
                        <Border Background="{DynamicResource ColorBrushBackground}" CornerRadius="5" Padding="7,2"
                                IsVisible="{Binding Category, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <TextBlock Text="{Binding Category}" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource ColorBrushGray2}"/>
                        </Border>
                        <Border Background="{DynamicResource ColorBrushBackground}" CornerRadius="5" Padding="7,2">
                            <TextBlock FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource ColorBrush4}"
                                       Text="{Binding Source, Converter={x:Static conv:ResourceSourceLabelConverter.Instance}}"/>
                        </Border>
                    </StackPanel>

                    <!-- Downloads row -->
                    <TextBlock Text="{Binding Downloads, Converter={x:Static conv:CompactNumberConverter.Instance}}"
                               FontSize="11" Foreground="{DynamicResource ColorBrushGray3}" Margin="0,12,0,0"/>

                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="28,8,28,28" RowDefinitions="Auto,Auto,Auto,*">
        <!-- Row 0: search box (full width) -->
        <controls:SearchBox SearchText="{Binding SearchText}" Margin="0,0,0,14"/>

        <!-- Row 1: resource-type chips (centered) -->
        <ListBox Grid.Row="1" ItemsSource="{Binding ResourceTypes}"
                 SelectedItem="{Binding SelectedTypeOption}"
                 Background="Transparent" BorderThickness="0" Padding="0"
                 MinHeight="0" HorizontalAlignment="Left"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Disabled">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="6"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="14,6"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="MinHeight" Value="0"/>
                    <Setter Property="CornerRadius" Value="8"/>
                    <Setter Property="Background" Value="{DynamicResource ColorBrushGray6}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource ColorBrushGray7}"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="Foreground" Value="{DynamicResource ColorBrushGray1}"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                </Style>
                <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                    <Setter Property="Background" Value="{DynamicResource ColorBrushGray7}"/>
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
                <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                    <Setter Property="Background" Value="{DynamicResource ColorBrush4}"/>
                    <Setter Property="CornerRadius" Value="8"/>
                    <Setter Property="TextElement.Foreground" Value="{DynamicResource ColorBrush1}"/>
                </Style>
                <Style Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter">
                    <Setter Property="Background" Value="{DynamicResource ColorBrush3}"/>
                    <Setter Property="CornerRadius" Value="8"/>
                    <Setter Property="TextElement.Foreground" Value="{DynamicResource ColorBrush1}"/>
                </Style>
                <Style Selector="ListBoxItem:selected">
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Style>
                <Style Selector="ListBoxItem:focusvisual">
                    <Setter Property="IsVisible" Value="False"/>
                </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
                <DataTemplate x:CompileBindings="False">
                        <TextBlock Text="{Binding Label}" FontSize="12" HorizontalAlignment="Center"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Row 2: filters (ComboBox) -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12" Margin="0,12,0,16">
            <controls:ComboBox ItemsSource="{Binding Sources}" SelectedItem="{Binding SelectedSourceOption}"
                         MinWidth="140" PlaceholderText="Source">
                <controls:ComboBox.ItemTemplate>
                    <DataTemplate x:CompileBindings="False">
                        <TextBlock Text="{Binding Label}" FontSize="13" FontWeight="SemiBold"/>
                    </DataTemplate>
                </controls:ComboBox.ItemTemplate>
            </controls:ComboBox>
            <controls:ComboBox ItemsSource="{Binding Loaders}" SelectedItem="{Binding SelectedLoaderOption}"
                         MinWidth="150" PlaceholderText="Loader">
                <controls:ComboBox.ItemTemplate>
                    <DataTemplate x:CompileBindings="False">
                        <TextBlock Text="{Binding Label}" FontSize="13" FontWeight="SemiBold"/>
                    </DataTemplate>
                </controls:ComboBox.ItemTemplate>
            </controls:ComboBox>
            <TextBox Classes="field" Text="{Binding GameVersion}" Watermark="Version (e.g. 1.20.1)"
                     MinWidth="150"/>
            <controls:ComboBox ItemsSource="{Binding Sorts}" SelectedItem="{Binding SelectedSortOption}"
                         MinWidth="160" PlaceholderText="Sort by">
                <controls:ComboBox.ItemTemplate>
                    <DataTemplate x:CompileBindings="False">
                        <TextBlock Text="{Binding Label}" FontSize="13" FontWeight="SemiBold"/>
                    </DataTemplate>
                </controls:ComboBox.ItemTemplate>
            </controls:ComboBox>
            <ProgressBar IsVisible="{Binding IsBusy}" IsIndeterminate="True"
                         Width="80" Height="3" VerticalAlignment="Center"
                         Foreground="{DynamicResource ColorBrush4}"/>
        </StackPanel>

        <!-- Row 3: cards grid (+ empty hint + pagination at bottom) -->
        <Grid Grid.Row="3">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <ItemsControl ItemsSource="{Binding Items}" ItemTemplate="{StaticResource ResourceCardTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <controls:WaterfallPanel ColumnWidth="300" ColumnSpacing="18" RowSpacing="18"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>

                    <controls:PaginationBar CurrentPage="{Binding CurrentPage}"
                                            TotalPages="{Binding TotalPages}"
                                            PreviousPageCommand="{Binding GoToPreviousPageCommand}"
                                            NextPageCommand="{Binding GoToNextPageCommand}"/>
                </StackPanel>
            </ScrollViewer>

            <Panel IsVisible="{Binding ShowEmptyHint}" VerticalAlignment="Top" HorizontalAlignment="Stretch" Margin="0,40,0,0">
                <TextBlock Text="No results — try a different filter or source."
                           FontSize="13" Foreground="{DynamicResource ColorBrushGray3}"
                           HorizontalAlignment="Center"/>
            </Panel>
        </Grid>
    </Grid>
</UserControl>
