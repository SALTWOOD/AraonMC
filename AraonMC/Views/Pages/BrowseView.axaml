<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:pages="using:AraonMC.ViewModels.Pages"
             xmlns:models="using:AraonMC.Core.Domain.Entities"
             xmlns:conv="using:AraonMC.Converters"
             xmlns:ctrl="using:AraonMC.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="640"
             x:Class="AraonMC.Views.Pages.BrowseView"
             x:DataType="pages:BrowseViewModel">

    <UserControl.Resources>
        <DataTemplate x:Key="ResourceCardTemplate" DataType="models:ResourceInfo">
            <Border Classes="card" Width="300" Margin="0,0,18,18" Padding="16">
                <StackPanel>
                    <!-- Header: icon + name/author + open-page button -->
                    <Grid ColumnDefinitions="44,*,28">
                        <Border Grid.Column="0" Width="44" Height="44" CornerRadius="10"
                                Background="White" ClipToBounds="True">
                            <Panel>
                                <!-- Initials fallback (visible until/unless the icon loads) -->
                                <TextBlock Text="{Binding IconKey}" FontSize="15" FontWeight="Bold"
                                           Foreground="{DynamicResource AccentForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <!-- Layered on top: transparent until the bitmap loads -->
                                <ctrl:RemoteImage Url="{Binding IconUrl}" Stretch="UniformToFill"/>
                            </Panel>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding Author}" FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="2" Classes="icon" Width="28" Height="28"
                                VerticalAlignment="Center"
                                Command="{Binding $parent[UserControl].((pages:BrowseViewModel)DataContext).OpenPageCommand}"
                                CommandParameter="{Binding}">
                            <Path Width="13" Height="13" Stretch="Uniform"
                                  Stroke="{DynamicResource TextMutedBrush}" StrokeThickness="1.8"
                                  StrokeLineCap="Round" StrokeJoin="Round"
                                  Fill="Transparent"
                                  Data="{StaticResource external-link}"/>
                        </Button>
                    </Grid>

                    <!-- Summary -->
                    <TextBlock Text="{Binding Summary}" FontSize="12" TextWrapping="Wrap"
                               MaxLines="3" TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,12,0,0"/>

                    <!-- Meta: category + source badge + downloads -->
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
                        <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="5" Padding="7,2"
                                IsVisible="{Binding Category, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <TextBlock Text="{Binding Category}" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Border>
                        <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="5" Padding="7,2">
                            <TextBlock FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       Text="{Binding Source, Converter={x:Static conv:ResourceSourceLabelConverter.Instance}}"/>
                        </Border>
                        <TextBlock Text="{Binding Downloads, Converter={x:Static conv:CompactNumberConverter.Instance}}"
                                   FontSize="11" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Actions: Detail opens the version-select window (always available — any version can be re-downloaded). -->
                    <Grid ColumnDefinitions="*" Margin="0,14,0,0">
                        <Button Grid.Column="0" Classes="accent"
                                Command="{Binding $parent[UserControl].((pages:BrowseViewModel)DataContext).DetailCommand}"
                                CommandParameter="{Binding}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center" Padding="0,9">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Path Width="13" Height="13" Stretch="Uniform"
                                      Stroke="{DynamicResource AccentForegroundBrush}" StrokeThickness="2"
                                      StrokeLineCap="Round" StrokeJoin="Round"
                                      Fill="Transparent"
                                      Data="{StaticResource info}"/>
                                <TextBlock Text="Detail" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="28,8,28,28" RowDefinitions="Auto,Auto,*">
        <!-- Row 0: resource-type chips (left) + search box (right) -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,4,0,14">
            <ListBox Grid.Column="0" ItemsSource="{Binding ResourceTypes}"
                     SelectedItem="{Binding SelectedTypeOption}"
                     Background="Transparent" BorderThickness="0" Padding="0"
                     MinHeight="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Disabled">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="6"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="14,6"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="MinHeight" Value="0"/>
                        <Setter Property="CornerRadius" Value="8"/>
                        <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                        <Setter Property="CornerRadius" Value="8"/>
                        <Setter Property="TextElement.Foreground" Value="{DynamicResource AccentForegroundBrush}"/>
                    </Style>
                    <Style Selector="ListBoxItem:selected">
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate x:CompileBindings="False">
                        <TextBlock Text="{Binding Label}" FontSize="12"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    CornerRadius="8" Width="280" Height="36" VerticalAlignment="Center">
                <Grid ColumnDefinitions="Auto,*">
                    <Path Grid.Column="0" Width="16" Height="16" Margin="10,0" Stretch="Uniform"
                          Fill="Transparent" Stroke="{DynamicResource TextMutedBrush}" StrokeThickness="1.5"
                          Data="{StaticResource search}"/>
                    <TextBox Grid.Column="1" Text="{Binding SearchText}"
                             Watermark="Search…"
                             Background="Transparent" BorderThickness="0"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             CaretBrush="{DynamicResource AccentBrush}"
                             VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Row 1: filters -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="0,0,0,16">
            <ComboBox ItemsSource="{Binding Sources}" SelectedItem="{Binding SelectedSourceOption}"
                      MinWidth="120" PlaceholderText="Source">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:CompileBindings="False">
                        <TextBlock Text="{Binding Label}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <ComboBox ItemsSource="{Binding Loaders}" SelectedItem="{Binding SelectedLoaderOption}"
                      MinWidth="130" PlaceholderText="Loader">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:CompileBindings="False">
                        <TextBlock Text="{Binding Label}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBox Classes="field" Text="{Binding GameVersion}" Watermark="Version (e.g. 1.20.1)"
                     MinWidth="150"/>
            <ComboBox ItemsSource="{Binding Sorts}" SelectedItem="{Binding SelectedSortOption}"
                      MinWidth="150" PlaceholderText="Sort by">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:CompileBindings="False">
                        <TextBlock Text="{Binding Label}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <ProgressBar IsVisible="{Binding IsBusy}" IsIndeterminate="True"
                         Width="80" Height="3" VerticalAlignment="Center"
                         Foreground="{DynamicResource AccentBrush}"/>
        </StackPanel>

        <!-- Row 2: cards grid (+ empty hint) -->
        <Grid Grid.Row="2">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Items}" ItemTemplate="{StaticResource ResourceCardTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>

            <Panel IsVisible="{Binding ShowEmptyHint}" VerticalAlignment="Top" HorizontalAlignment="Stretch" Margin="0,40,0,0">
                <TextBlock Text="No results — try a different filter or source."
                           FontSize="13" Foreground="{DynamicResource TextMutedBrush}"
                           HorizontalAlignment="Center"/>
            </Panel>
        </Grid>
    </Grid>
</UserControl>
