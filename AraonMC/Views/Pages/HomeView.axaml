<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:pages="using:AraonMC.ViewModels.Pages"
             xmlns:models="using:AraonMC.Core.Domain.Entities"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="640"
             x:Class="AraonMC.Views.Pages.HomeView"
             x:DataType="pages:HomeViewModel">

    <UserControl.Resources>
        <DataTemplate x:Key="NewsTemplate" DataType="models:NewsItem">
            <StackPanel Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,5">
                    <Border Background="{DynamicResource ColorBrushSemiTransparent}"
                            CornerRadius="5"
                            Padding="7,2">
                        <TextBlock Text="{Binding Tag}" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource ColorBrush4}"/>
                    </Border>
                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14"
                               Foreground="{DynamicResource ColorBrushGray1}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="{Binding Body}" FontSize="12" TextWrapping="Wrap"
                           Foreground="{DynamicResource ColorBrushGray2}"/>
                <TextBlock Text="{Binding Date}" FontSize="11" Margin="0,4,0,0"
                           Foreground="{DynamicResource ColorBrushGray3}"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="InstanceOptionTemplate" DataType="models:GameInstance">
            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,2">
                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding DisplayLoader}" FontSize="11"
                           Foreground="{DynamicResource ColorBrushGray3}" VerticalAlignment="Center"/>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid ColumnDefinitions="*,340" Margin="28,8,28,28">

        <!-- Hero instance card -->
        <Border Grid.Column="0" Classes="card" Padding="0" ClipToBounds="True" VerticalAlignment="Top">
            <Grid RowDefinitions="150,Auto,Auto,Auto,Auto">

                <!-- Cover -->
                <Border Grid.Row="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                            <GradientStop Offset="0" Color="{DynamicResource ColorObject2}"/>
                            <GradientStop Offset="1" Color="{DynamicResource ColorObject4}"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <TextBlock Text="{Binding SelectedInstance.CoverKey}"
                                   FontSize="72" FontWeight="Black"
                                   Foreground="{DynamicResource ColorBrush1}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Opacity="0.55"/>
                        <TextBlock Text="{Binding SelectedInstance.Name}"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource ColorBrush1}"
                                   HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                   Margin="0,0,0,18"/>
                    </Grid>
                </Border>

                <!-- Version line -->
                <StackPanel Grid.Row="1" Margin="24,18,24,2">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding SelectedInstance.DisplayVersion}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ColorBrushGray1}"/>
                        <TextBlock Text="·" Foreground="{DynamicResource ColorBrushGray3}"/>
                        <TextBlock Text="{Binding SelectedInstance.DisplayLoader}"
                                   Foreground="{DynamicResource ColorBrushGray2}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Stats -->
                <Grid Grid.Row="2" ColumnDefinitions="*,*,*" Margin="24,14,24,0">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="LAST PLAYED" FontSize="10" Foreground="{DynamicResource ColorBrushGray3}"/>
                        <TextBlock Text="{Binding SelectedInstance.LastPlayed}" FontSize="13" Margin="0,3,0,0"
                                   Foreground="{DynamicResource ColorBrushGray1}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="PLAYTIME" FontSize="10" Foreground="{DynamicResource ColorBrushGray3}"/>
                        <TextBlock Text="{Binding SelectedInstance.PlayTime}" FontSize="13" Margin="0,3,0,0"
                                   Foreground="{DynamicResource ColorBrushGray1}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="GROUP" FontSize="10" Foreground="{DynamicResource ColorBrushGray3}"/>
                        <TextBlock Text="{Binding SelectedInstance.Group}" FontSize="13" Margin="0,3,0,0"
                                   Foreground="{DynamicResource ColorBrushGray1}"/>
                    </StackPanel>
                </Grid>

                <!-- Instance selector -->
                <StackPanel Grid.Row="3" Margin="24,18,24,0">
                    <TextBlock Text="INSTANCE" FontSize="10" Foreground="{DynamicResource ColorBrushGray3}" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding Instances}"
                              SelectedItem="{Binding SelectedInstance}"
                              ItemTemplate="{StaticResource InstanceOptionTemplate}"
                              HorizontalAlignment="Stretch"
                              MinWidth="280"/>
                </StackPanel>

                <!-- PLAY -->
                <StackPanel Grid.Row="4" Margin="24,20,24,24" HorizontalAlignment="Left">
                    <Button Classes="accent" Command="{Binding PlayCommand}" Padding="32,14">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Path Width="16" Height="16" Stretch="Uniform"
                                  Fill="{DynamicResource ColorBrush1}" Stroke="Transparent"
                                  Data="{StaticResource play}"/>
                            <TextBlock Text="PLAY" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- News -->
        <Border Grid.Column="1" Classes="card" Padding="20" Margin="20,0,0,0" VerticalAlignment="Top">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="News &amp; Updates" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource ColorBrushGray1}"/>
                    <ItemsControl ItemsSource="{Binding News}" ItemTemplate="{StaticResource NewsTemplate}" Margin="0,14,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
