<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:pages="using:AraonMC.ViewModels.Pages"
             xmlns:models="using:AraonMC.Core.Domain.Entities"
             xmlns:conv="using:AraonMC.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="640"
             x:Class="AraonMC.Views.Pages.ModsView"
             x:DataType="pages:ModsViewModel">

    <UserControl.Resources>
        <DataTemplate x:Key="ModCardTemplate" DataType="models:ModInfo">
            <Border Classes="card" Width="300" Margin="0,0,18,18" Padding="16">
                <StackPanel>
                    <!-- Header -->
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Border Width="44" Height="44" CornerRadius="10" Background="{DynamicResource AccentBrush}">
                            <TextBlock Text="{Binding IconKey}" FontSize="15" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentForegroundBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding Author}" FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Summary -->
                    <TextBlock Text="{Binding Summary}" FontSize="12" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,12,0,0"/>

                    <!-- Meta -->
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
                        <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="5" Padding="7,2">
                            <TextBlock Text="{Binding Category}" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Border>
                        <TextBlock Text="{Binding Downloads, Converter={x:Static conv:CompactNumberConverter.Instance}}"
                                   FontSize="11" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Actions -->
                    <Grid ColumnDefinitions="*,*" Margin="0,14,0,0">
                        <Button Grid.Column="0" Classes="accent"
                                Command="{Binding $parent[UserControl].((pages:ModsViewModel)DataContext).InstallCommand}"
                                CommandParameter="{Binding}"
                                IsVisible="{Binding !Installed}" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center" Padding="0,9">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Path Width="13" Height="13" Stretch="Uniform"
                                      Fill="{DynamicResource AccentForegroundBrush}" Stroke="Transparent"
                                      Data="{StaticResource DownloadIcon}"/>
                                <TextBlock Text="Install" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="0" Classes="subtle" IsEnabled="False"
                                IsVisible="{Binding Installed}" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center" Padding="0,9">
                            <TextBlock Text="Installed" Foreground="{DynamicResource OnlineBrush}" FontWeight="SemiBold"/>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="28,8,28,28" RowDefinitions="Auto,*">
        <!-- Toolbar -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,4,0,18">
            <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    CornerRadius="8" Width="340" Height="36">
                <Grid ColumnDefinitions="Auto,*">
                    <Path Grid.Column="0" Width="16" Height="16" Margin="10,0" Stretch="Uniform"
                          Fill="Transparent" Stroke="{DynamicResource TextMutedBrush}" StrokeThickness="1.5"
                          Data="{StaticResource SearchIcon}"/>
                    <TextBox Grid.Column="1" Text="{Binding SearchText}"
                             Watermark="Search mods..."
                             Background="Transparent" BorderThickness="0"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             CaretBrush="{DynamicResource AccentBrush}"
                             VerticalAlignment="Center"/>
                </Grid>
            </Border>
            <TextBlock Grid.Column="2" Text="Browse" FontSize="13"
                       Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
        </Grid>

        <!-- Grid of mods -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Items}" ItemTemplate="{StaticResource ModCardTemplate}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
